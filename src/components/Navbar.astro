---
---
<header class="header">
    <div class="header-container">
        <a href="#" class="logo" onclick="showSection('home')">
            <picture>
                <source srcset="/assets/kat3logo.webp" type="image/webp">
                <img src="/assets/Kat3logo final website-2.png-Copy.png" alt="Kat3athlete — Ironman Certified Coach" class="logo-img" width="400" height="174">
            </picture>
        </a>
        <button class="menu-toggle" id="menu-toggle" onclick="toggleMenu()" aria-label="Menu" aria-expanded="false">
            <span></span><span></span><span></span>
        </button>
        <div class="mobile-menu" id="mobile-menu">
            <nav class="nav">
                <button class="nav-link active" onclick="showSection('home')" data-section="home" data-i18n="nav_home">Home</button>
                <button class="nav-link" onclick="showSection('about')" data-section="about" data-i18n="nav_about">About Me</button>
                <button class="nav-link" onclick="showSection('services')" data-section="services" data-i18n="nav_services">Services</button>
                <button class="nav-link" onclick="showSection('testimonials')" data-section="testimonials" data-i18n="nav_testimonials">Testimonials</button>
                <button class="nav-link" onclick="showSection('contact')" data-section="contact" data-i18n="nav_contact">Contact</button>
            </nav>
            <div class="lang-switcher">
                <button class="lang-btn active" data-lang="en" onclick="setLang('en')">EN</button>
                <button class="lang-btn" data-lang="es" onclick="setLang('es')">ES</button>
                <button class="lang-btn" data-lang="it" onclick="setLang('it')">IT</button>
                <button class="lang-btn" data-lang="pt" onclick="setLang('pt')">PT</button>
            </div>
        </div>
    </div>
</header>
