---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import TestimonialModal from '../components/TestimonialModal.astro';
---
<BaseLayout>

<Navbar />

<main id="main-content">

<!-- HOME -->
<section id="home" class="section active">
    <div class="hero">
        <div class="hero-content">
            <div class="hero-badge" data-i18n="hero_badge">Ironman Certified Coach</div>
            <h1>
                Kat3
                <span class="highlight">athlete</span>
            </h1>
            <div class="hero-divider"></div>
            <p class="hero-subtitle" data-i18n="hero_subtitle">Complete Triathlon Training</p>
            <p class="hero-description" data-i18n="hero_description">Professional coach certified by IRONMAN with over 6 years of experience training athletes of all levels. Specialist in preparation for sprint, Olympic, 70.3 and Full Ironman triathlons. Transform your performance with comprehensive training designed to push your limits.</p>
            <div class="btn-group">
                <button class="btn btn-primary" onclick="showSection('services')" data-i18n="btn_programs">View Training Programs</button>
                <button class="btn btn-secondary" onclick="showSection('contact')" data-i18n="btn_start">Start Your Training</button>
            </div>
        </div>
    </div>
</section>

<!-- ABOUT -->
<section id="about" class="section">
    <div class="container">
        <div class="section-header">
            <span class="section-tag" data-i18n="about_tag">Meet Me</span>
            <h2 class="section-title" data-i18n="about_title">About Me</h2>
            <p class="section-subtitle" data-i18n="about_subtitle">Your IRONMAN certified coach on the road to the finish line</p>
        </div>
        <div class="about-grid about-grid--solo">
            <div class="about-content">
                <h3 data-i18n="about_h3">Training Champions Since 2021</h3>
                <p data-i18n="about_p1">I'm Katherine Gomez Aya, IRONMAN Certified Coach and triathlon specialist — 16 years as both athlete and coach, having lived every stage of the journey: the early mornings, long training sessions, mental battles, and the satisfaction of crossing the finish line.</p>
                <p data-i18n="about_p2">Since 2021, I coach athletes of all levels, from first-timers to competitors targeting IRONMAN 70.3 and 140.6. Every plan is fully personalized — blending sports science, structured methodology, and a champion's mindset across swimming, cycling, and running to maximize performance and minimize injury risk.</p>
                <p data-i18n="about_p3">My mission: guide you step by step toward your goals — your first Sprint Triathlon, a 70.3, or the podium at a full IRONMAN 140.6.</p>
                <p data-i18n="about_p4"><em>Because every finish line starts with a decision to begin.</em></p>
                <div class="proven-results">
                    <h4 class="proven-title" data-i18n="proven_title">Proven Results</h4>
                    <div class="proven-grid">
                        <div class="proven-item">
                            <div class="proven-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M8 21h8M12 17v4M7 4h10l-1 8a5 5 0 01-8 0L7 4zM5 4H3l1 5a3 3 0 003 2M19 4h2l-1 5a3 3 0 01-3 2"/>
                                </svg>
                            </div>
                            <div class="proven-text">
                                <span class="proven-stat" data-i18n="proven_stat1_title">Ironman 70.3</span>
                                <span class="proven-sub" data-i18n="proven_stat1_sub">Finisher</span>
                            </div>
                        </div>
                        <div class="proven-divider"></div>
                        <div class="proven-item">
                            <div class="proven-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    <polygon points="12,2 15.09,8.26 22,9.27 17,14.14 18.18,21.02 12,17.77 5.82,21.02 7,14.14 2,9.27 8.91,8.26"/>
                                </svg>
                            </div>
                            <div class="proven-text">
                                <span class="proven-stat" data-i18n="proven_stat2_title">6+ Years</span>
                                <span class="proven-sub" data-i18n="proven_stat2_sub">Coaching Experience</span>
                            </div>
                        </div>
                        <div class="proven-divider"></div>
                        <div class="proven-item">
                            <div class="proven-icon">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
                                    <path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/>
                                </svg>
                            </div>
                            <div class="proven-text">
                                <span class="proven-stat" data-i18n="proven_stat3_title">Athletes</span>
                                <span class="proven-sub" data-i18n="proven_stat3_sub">Worldwide</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- TRIATHLON JOURNEY -->
        <div class="journey-section">
            <h3 class="journey-title" data-i18n="journey_title">The Triathlon Journey</h3>
            <div class="journey-grid">
                <!-- Columna 1 (~1142px): 13, 7, 11 -->
                <div class="journey-col">
                    <div class="journey-item" onclick="openLightbox('https://pub-0789916971714c4181501344ff932029.r2.dev/journey-13.webp','Ironman 70.3 Barcelona — finisher medal')">
                        <picture><source srcset="https://pub-0789916971714c4181501344ff932029.r2.dev/journey-13.webp" type="image/webp">
                        <img src="https://pub-0789916971714c4181501344ff932029.r2.dev/13.jpg" alt="Ironman 70.3 Barcelona — finisher medal" loading="lazy"></picture>
                    </div>
                    <div class="journey-item" onclick="openLightbox('https://pub-0789916971714c4181501344ff932029.r2.dev/journey-7.webp','Running — Doha skyline')">
                        <picture><source srcset="https://pub-0789916971714c4181501344ff932029.r2.dev/journey-7.webp" type="image/webp">
                        <img src="https://pub-0789916971714c4181501344ff932029.r2.dev/7.JPG" alt="Running — Doha skyline" loading="lazy"></picture>
                    </div>
                    <div class="journey-item" onclick="openLightbox('https://pub-0789916971714c4181501344ff932029.r2.dev/journey-11.webp','Cycling — road training')">
                        <picture><source srcset="https://pub-0789916971714c4181501344ff932029.r2.dev/journey-11.webp" type="image/webp">
                        <img src="https://pub-0789916971714c4181501344ff932029.r2.dev/11.JPG" alt="Cycling — road training" loading="lazy"></picture>
                    </div>
                </div>
                <!-- Columna 2 (~1225px): 4, 8, 6 -->
                <div class="journey-col">
                    <div class="journey-item" onclick="openLightbox('https://pub-0789916971714c4181501344ff932029.r2.dev/journey-4.webp','Running — Ironman 70.3 Cartagena')">
                        <picture><source srcset="https://pub-0789916971714c4181501344ff932029.r2.dev/journey-4.webp" type="image/webp">
                        <img src="https://pub-0789916971714c4181501344ff932029.r2.dev/4.JPG" alt="Running — Ironman 70.3 Cartagena" loading="lazy"></picture>
                    </div>
                    <div class="journey-item" onclick="openLightbox('https://pub-0789916971714c4181501344ff932029.r2.dev/journey-8.webp','Running — race Doha')">
                        <picture><source srcset="https://pub-0789916971714c4181501344ff932029.r2.dev/journey-8.webp" type="image/webp">
                        <img src="https://pub-0789916971714c4181501344ff932029.r2.dev/8.JPG" alt="Running — race Doha" loading="lazy"></picture>
                    </div>
                    <div class="journey-item" onclick="openLightbox('https://pub-0789916971714c4181501344ff932029.r2.dev/journey-6.webp','Beach triathlon — green suit')">
                        <picture><source srcset="https://pub-0789916971714c4181501344ff932029.r2.dev/journey-6.webp" type="image/webp">
                        <img src="https://pub-0789916971714c4181501344ff932029.r2.dev/6.JPG" alt="Beach triathlon — green suit" loading="lazy"></picture>
                    </div>
                </div>
                <!-- Columna 3 (~1167px): 9, 12, 1 -->
                <div class="journey-col">
                    <div class="journey-item" onclick="openLightbox('https://pub-0789916971714c4181501344ff932029.r2.dev/journey-9.webp','Swimming — open water')">
                        <picture><source srcset="https://pub-0789916971714c4181501344ff932029.r2.dev/journey-9.webp" type="image/webp">
                        <img src="https://pub-0789916971714c4181501344ff932029.r2.dev/9.JPG" alt="Swimming — open water" loading="lazy"></picture>
                    </div>
                    <div class="journey-item" onclick="openLightbox('https://pub-0789916971714c4181501344ff932029.r2.dev/journey-12.webp','Cycling — TT position')">
                        <picture><source srcset="https://pub-0789916971714c4181501344ff932029.r2.dev/journey-12.webp" type="image/webp">
                        <img src="https://pub-0789916971714c4181501344ff932029.r2.dev/12.JPG" alt="Cycling — TT position" loading="lazy"></picture>
                    </div>
                    <div class="journey-item" onclick="openLightbox('https://pub-0789916971714c4181501344ff932029.r2.dev/journey-1.webp','Preparing — race day')">
                        <picture><source srcset="https://pub-0789916971714c4181501344ff932029.r2.dev/journey-1.webp" type="image/webp">
                        <img src="https://pub-0789916971714c4181501344ff932029.r2.dev/1.jpeg" alt="Preparing — race day" loading="lazy"></picture>
                    </div>
                </div>
                <!-- Columna 4 (~1346px): 10, 2, 3, 5 -->
                <div class="journey-col">
                    <div class="journey-item" onclick="openLightbox('https://pub-0789916971714c4181501344ff932029.r2.dev/journey-10.webp','Cycling — race pace')">
                        <picture><source srcset="https://pub-0789916971714c4181501344ff932029.r2.dev/journey-10.webp" type="image/webp">
                        <img src="https://pub-0789916971714c4181501344ff932029.r2.dev/10.JPG" alt="Cycling — race pace" loading="lazy"></picture>
                    </div>
                    <div class="journey-item" onclick="openLightbox('https://pub-0789916971714c4181501344ff932029.r2.dev/journey-2.webp','Running — waterfront promenade')">
                        <picture><source srcset="https://pub-0789916971714c4181501344ff932029.r2.dev/journey-2.webp" type="image/webp">
                        <img src="https://pub-0789916971714c4181501344ff932029.r2.dev/2.jpeg" alt="Running — waterfront promenade" loading="lazy"></picture>
                    </div>
                    <div class="journey-item" onclick="openLightbox('https://pub-0789916971714c4181501344ff932029.r2.dev/journey-5.webp','Beach triathlon — green suit')">
                        <picture><source srcset="https://pub-0789916971714c4181501344ff932029.r2.dev/journey-5.webp" type="image/webp">
                        <img src="https://pub-0789916971714c4181501344ff932029.r2.dev/5.JPG" alt="Beach triathlon — green suit" loading="lazy"></picture>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- SERVICES -->
<section id="services" class="section">
    <div class="container">
        <div class="section-header">
            <span class="section-tag" data-i18n="services_tag">Programs</span>
            <h2 class="section-title" data-i18n="services_title">Training</h2>
            <p class="section-subtitle" data-i18n="services_subtitle">Sprint · Olympic · Ironman 70.3 · Running · Full Ironman</p>
        </div>
        <div class="services-grid">
            <div class="service-card">
                <div class="service-icon-wrap">
                    <img src="https://pub-0789916971714c4181501344ff932029.r2.dev/triatlon_1.png" alt="" class="service-icon-img service-icon-img--triathlon" aria-hidden="true">
                </div>
                <h3 data-i18n="svc1_title">Sprint &amp; Olympic Triathlon</h3>
                <p data-i18n="svc1_desc">Complete 3-discipline plan. Progressive training for your first triathlon or to improve your time. Includes T1 and T2 transition strategies.</p>
                <div class="service-price" data-i18n="svc1_price">$70/month</div>
            </div>
            <div class="service-card">
                <div class="service-icon-wrap">
                    <img src="https://pub-0789916971714c4181501344ff932029.r2.dev/ironman-70-3.svg" alt="" class="service-icon-img service-icon-img--ironman" aria-hidden="true">
                </div>
                <h3 data-i18n="svc2_title">Ironman 70.3</h3>
                <p data-i18n="svc2_desc">Specialized preparation for half Ironman: 1.9km swim + 90km cycling + 21.1km run. 16-20 week plan with scientific periodization.</p>
                <div class="service-price" data-i18n="svc2_price">$70/month</div>
            </div>
            <div class="service-card">
                <div class="service-icon-wrap">
                    <img src="https://pub-0789916971714c4181501344ff932029.r2.dev/running.svg" alt="" class="service-icon-img service-icon-img--running" aria-hidden="true">
                </div>
                <h3 data-i18n="svc3_title">Running</h3>
                <p data-i18n="svc3_desc">5K, 10K, Half Marathon and Full Marathon programs. Race technique, interval training, injury prevention and pace plans for your specific goal.</p>
                <div class="service-price" data-i18n="svc3_price">$70/month</div>
            </div>
            <div class="service-card">
                <div class="service-icon-wrap">
                    <img src="https://pub-0789916971714c4181501344ff932029.r2.dev/ironman-140-6.png" alt="" class="service-icon-img service-icon-img--ironman140" aria-hidden="true">
                </div>
                <h3 data-i18n="svc4_title">Ironman 140.6 Full</h3>
                <p data-i18n="svc4_desc">Elite training for the ultimate challenge: 3.8km swim + 180km cycling + 42.2km marathon. 24-32 week plan. Includes sports nutrition and winning mindset.</p>
                <div class="service-price" data-i18n="svc4_price">$100/month</div>
            </div>
        </div>
        <div style="text-align:center; margin-top:50px;">
            <button class="btn btn-primary" onclick="showSection('contact')" data-i18n="btn_free_eval">Book Your Free Assessment</button>
        </div>
    </div>
</section>

<!-- TESTIMONIALS -->
<section id="testimonials" class="section">
    <div class="container">
        <div class="section-header">
            <span class="section-tag" data-i18n="test_tag">Success Stories</span>
            <h2 class="section-title" data-i18n="test_title">Testimonials</h2>
            <p class="section-subtitle" data-i18n="test_subtitle">Athletes who crossed the finish line with my training</p>
        </div>
        <div class="testimonials-grid" id="testimonials-grid">
            <div class="testimonial-card">
                <p class="testimonial-text">I never imagined I would finish an Ironman. Katherine designed a perfect plan for me that took me from not knowing how to swim to completing my first 70.3 in 6 hours 45 minutes. Her knowledge of the 3 disciplines and the mindset she taught me were key. Now I'm going for the Full!</p>
                <div class="testimonial-author">
                    <div class="testimonial-avatar">MR</div>
                    <div class="testimonial-info">
                        <h4>Miguel Rodríguez</h4>
                        <span>Ironman 70.3 Finisher, Mexico City</span>
                    </div>
                </div>
            </div>
            <div class="testimonial-card">
                <p class="testimonial-text">I dropped my marathon time from 4:30 to 3:45 in just 4 months with Katherine's training. Her focus on running technique and interval sessions made all the difference. Consistency and a well-structured plan work.</p>
                <div class="testimonial-author">
                    <div class="testimonial-avatar">SL</div>
                    <div class="testimonial-info">
                        <h4>Sofía López</h4>
                        <span>Marathon Runner, Guadalajara</span>
                    </div>
                </div>
            </div>
            <div class="testimonial-card">
                <p class="testimonial-text">I started from scratch at 45. Katherine prepared me for my first sprint triathlon and now, two years later, I've completed 3 Ironman 140.6. Her patience, technical knowledge and constant motivation transformed me into the athlete I always wanted to be.</p>
                <div class="testimonial-author">
                    <div class="testimonial-avatar">RH</div>
                    <div class="testimonial-info">
                        <h4>Roberto Hernández</h4>
                        <span>3x Ironman Finisher, Monterrey</span>
                    </div>
                </div>
            </div>
            <div class="testimonial-card">
                <p class="testimonial-text">Katherine's swimming training is extraordinary. I went from being afraid of water to swimming 3.8km non-stop. Her teaching technique is clear, sessions are challenging but progressive, and she is always available to correct and motivate. 100% recommended.</p>
                <div class="testimonial-author">
                    <div class="testimonial-avatar">AC</div>
                    <div class="testimonial-info">
                        <h4>Andrea Castillo</h4>
                        <span>Open Water Swimmer, CDMX</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="add-testimonial-wrap">
            <button class="btn-outline" onclick="openModal()" data-i18n="btn_add_testimonial">+ Add Testimonial</button>
        </div>
    </div>
</section>

<!-- CONTACT -->
<section id="contact" class="section">
    <div class="container">
        <div class="section-header">
            <span class="section-tag" data-i18n="contact_tag">Let's Begin</span>
            <h2 class="section-title" data-i18n="contact_title">Contact</h2>
            <p class="section-subtitle" data-i18n="contact_subtitle">Take the first step towards your next finish line</p>
        </div>
        <div class="contact-grid">
            <div class="contact-info">
                <h3 data-i18n="contact_info_title">Contact Information</h3>
                <div class="contact-item">
                    <div class="contact-icon">
                        <svg viewBox="0 0 24 24"><rect x="2" y="4" width="20" height="16" rx="3"/><polyline points="2,4 12,13 22,4"/></svg>
                    </div>
                    <div>
                        <h4 data-i18n="contact_email_label">Email</h4>
                        <p>katherinegomezaya@gmail.com</p>
                    </div>
                </div>
                <div class="contact-item">
                    <div class="contact-icon">
                        <svg viewBox="0 0 24 24"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z"/></svg>
                    </div>
                    <div>
                        <h4 data-i18n="contact_phone_label">Phone / WhatsApp</h4>
                        <p>+974 33 106 749</p>
                    </div>
                </div>
                <div class="contact-item">
                    <div class="contact-icon">
                        <svg viewBox="0 0 24 24"><path d="M12 2C8.1 2 5 5.1 5 9c0 5.2 7 13 7 13s7-7.8 7-13c0-3.9-3.1-7-7-7z"/><circle cx="12" cy="9" r="2.5"/></svg>
                    </div>
                    <div>
                        <h4 data-i18n="contact_location_label">Location</h4>
                        <p id="contact-location-text">Doha, Qatar</p>
                    </div>
                </div>
            </div>
            <div class="contact-form">
                <form id="contact-form" onsubmit="handleFormSubmit(event)">
                    <div class="form-group">
                        <label for="nombre" data-i18n="form_name_label">Full Name</label>
                        <input type="text" id="nombre" name="nombre" required data-i18n-ph="form_name_placeholder" placeholder="Your name">
                    </div>
                    <div class="form-group">
                        <label for="email" data-i18n="form_email_label">Email Address</label>
                        <input type="email" id="email" name="email" required data-i18n-ph="form_email_placeholder" placeholder="your@email.com">
                    </div>
                    <div class="form-group">
                        <label for="telefono" data-i18n="form_phone_label">Phone</label>
                        <input type="tel" id="telefono" name="telefono" data-i18n-ph="form_phone_placeholder" placeholder="+974 33 106 749">
                    </div>
                    <div class="form-group">
                        <label for="servicio" data-i18n="form_service_label">Training Type</label>
                        <input type="text" id="servicio" name="servicio" data-i18n-ph="form_service_placeholder" placeholder="e.g.: Swimming, Cycling, Sprint Triathlon, Ironman...">
                    </div>
                    <div class="form-group">
                        <label for="mensaje" data-i18n="form_message_label">Your Message</label>
                        <textarea id="mensaje" name="mensaje" required data-i18n-ph="form_message_placeholder" placeholder="Tell me about your current level, your goal and any previous injuries..."></textarea>
                    </div>
                    <button type="submit" id="contact-submit-btn" class="btn btn-primary" style="width:100%;" data-i18n="btn_submit">Request Free Assessment</button>
                    <div id="contact-success" style="display:none; text-align:center; margin-top:20px; padding:16px; background:rgba(228,0,43,0.1); border:1px solid var(--iron-red); border-radius:8px; font-family:var(--font-display); color:var(--iron-red); letter-spacing:0.05em;"></div>
                </form>
            </div>
        </div>
    </div>
</section>

</main>

<!-- LIGHTBOX -->
<div id="journey-lightbox" onclick="closeLightbox()">
    <button id="lightbox-close" onclick="closeLightbox()" aria-label="Close">×</button>
    <img id="lightbox-img" src="" alt="" onclick="event.stopPropagation()">
</div>

<Footer />
<TestimonialModal />

