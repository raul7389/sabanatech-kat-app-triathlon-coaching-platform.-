let currentLang = 'en';

/* ─── LANGUAGE ─── */
function setLang(lang) {
    currentLang = lang;
    document.documentElement.lang = lang;
    document.querySelectorAll('.lang-btn').forEach(btn => {
        btn.classList.toggle('active', btn.dataset.lang === lang);
    });
    const t = T[lang];
    document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        if (t[key] !== undefined) el.textContent = t[key];
    });
    document.querySelectorAll('[data-i18n-ph]').forEach(el => {
        const key = el.getAttribute('data-i18n-ph');
        if (t[key] !== undefined) el.placeholder = t[key];
    });
    const locEl = document.getElementById('contact-location-text');
    if (locEl && t.contact_location_text) locEl.innerHTML = t.contact_location_text;
}

/* ─── NAVIGATION ─── */
function showSection(sectionId) {
    document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
    const target = document.getElementById(sectionId);
    if (target) {
        target.classList.add('active');
        requestAnimationFrame(() => window.scrollTo({ top: 0, behavior: 'smooth' }));
    }
    document.querySelectorAll('.nav-link').forEach(link => {
        link.classList.toggle('active', link.getAttribute('data-section') === sectionId);
    });
    closeMenu();
}

/* ─── CONTACT FORM ─── */
async function handleFormSubmit(e) {
    e.preventDefault();
    const nombre = document.getElementById('nombre').value.trim();
    const email = document.getElementById('email').value.trim();
    const telefono = document.getElementById('telefono').value.trim();
    const servicio = document.getElementById('servicio').value.trim();
    const mensaje = document.getElementById('mensaje').value.trim();

    const btn = document.getElementById('contact-submit-btn');
    btn.disabled = true;
    btn.textContent = 'Sending...';

    try {
        const formData = new FormData();
        formData.append('access_key', '7dea30f0-2001-4f75-89ad-fc9de2293022');
        formData.append('subject', 'Nueva consulta de entrenamiento - Kat3athlete');
        formData.append('from_name', nombre);
        formData.append('email', email);
        formData.append('message',
            `Nueva consulta recibida:\n\n` +
            `Nombre: ${nombre}\n` +
            `Email: ${email}\n` +
            `Teléfono: ${telefono || 'No indicado'}\n` +
            `Tipo de entrenamiento: ${servicio || 'No indicado'}\n\n` +
            `Mensaje:\n${mensaje}`
        );
        await fetch('https://api.web3forms.com/submit', { method: 'POST', body: formData });
    } catch (_) {}

    e.target.reset();
    e.target.querySelectorAll('input, textarea').forEach(el => el.classList.remove('valid', 'invalid'));
    btn.disabled = false;
    btn.setAttribute('data-i18n', 'btn_submit');
    btn.textContent = T[currentLang]?.btn_submit || 'Request Free Assessment';

    const successEl = document.getElementById('contact-success');
    successEl.textContent = T[currentLang]?.form_success || 'Thank you! I will contact you soon.';
    successEl.style.display = 'block';
    setTimeout(() => { successEl.style.display = 'none'; }, 5000);
}

/* ─── TESTIMONIALS ─── */

async function submitTestimonial(e) {
    e.preventDefault();
    const name = document.getElementById('modal-name').value.trim();
    const email = document.getElementById('modal-email').value.trim();
    const role = document.getElementById('modal-role').value.trim();
    const text = document.getElementById('modal-text').value.trim();
    if (!name || !email || !role || !text) return;

    const btn = document.getElementById('modal-submit-btn');
    btn.disabled = true;
    btn.textContent = 'Sending...';

    try {
        const formData = new FormData();
        formData.append('access_key', '7dea30f0-2001-4f75-89ad-fc9de2293022');
        formData.append('subject', 'Nuevo testimonio recibido - Kat3athlete');
        formData.append('from_name', name);
        formData.append('email', email);
        formData.append('message',
            `Nuevo testimonio recibido:\n\n` +
            `Nombre: ${name}\n` +
            `Email: ${email}\n` +
            `Rol / Logro: ${role}\n\n` +
            `Testimonio:\n${text}`
        );
        await fetch('https://api.web3forms.com/submit', { method: 'POST', body: formData });
    } catch (_) {}

    e.target.reset();
    btn.disabled = false;
    btn.setAttribute('data-i18n', 'modal_submit');
    btn.textContent = T[currentLang]?.modal_submit || 'Submit Testimonial';

    const successEl = document.getElementById('modal-success');
    if (successEl) {
        successEl.style.display = 'block';
        setTimeout(() => {
            successEl.style.display = 'none';
            closeModal();
        }, 2500);
    } else {
        closeModal();
    }
}

function escapeHtml(str) {
    return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

/* ─── MODAL ─── */
function openModal() {
    document.getElementById('modal-overlay').classList.add('open');
    document.body.style.overflow = 'hidden';
    const successEl = document.getElementById('modal-success');
    if (successEl) successEl.style.display = 'none';
}
function closeModal() {
    document.getElementById('modal-overlay').classList.remove('open');
    document.body.style.overflow = '';
}
function closeModalOutside(e) {
    if (e.target === document.getElementById('modal-overlay')) closeModal();
}

/* ─── HAMBURGER MENU ─── */
function toggleMenu() {
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const isOpen = menu.classList.toggle('open');
    toggle.classList.toggle('open', isOpen);
    toggle.setAttribute('aria-expanded', isOpen);
}
function closeMenu() {
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    menu.classList.remove('open');
    toggle.classList.remove('open');
    toggle.setAttribute('aria-expanded', 'false');
}

/* ─── TESTIMONIALS CAROUSEL ─── */
function scrollTestimonials(direction) {
    const grid = document.getElementById('testimonials-grid');
    if (!grid) return;
    const cardWidth = grid.querySelector('.testimonial-card')?.offsetWidth || 380;
    grid.scrollBy({ left: direction * (cardWidth + 24), behavior: 'smooth' });
}

/* ─── LIGHTBOX ─── */
function openLightbox(src, alt) {
    const lb = document.getElementById('journey-lightbox');
    const img = document.getElementById('lightbox-img');
    img.src = src;
    img.alt = alt || '';
    lb.classList.add('open');
    document.body.style.overflow = 'hidden';
}
function closeLightbox() {
    document.getElementById('journey-lightbox').classList.remove('open');
    document.body.style.overflow = '';
}

/* ─── FORM VALIDATION ─── */
function validateField(input) {
    if (!input.value.trim()) {
        input.classList.remove('valid', 'invalid');
        return;
    }
    const isValid = input.checkValidity();
    input.classList.toggle('valid', isValid);
    input.classList.toggle('invalid', !isValid);
}

/* ─── INIT ─── */
document.addEventListener('DOMContentLoaded', () => {
    setLang('en');
    showSection('home');

    document.querySelectorAll('.nav-link').forEach(btn => {
        btn.addEventListener('click', closeMenu);
    });

    document.querySelectorAll('#contact-form input, #contact-form textarea').forEach(input => {
        input.addEventListener('blur', () => validateField(input));
        input.addEventListener('input', () => {
            if (input.classList.contains('invalid') || input.classList.contains('valid')) {
                validateField(input);
            }
        });
    });

    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeLightbox(); });

    /* ─── TESTIMONIALS SWIPE ─── */
    const tGrid = document.getElementById('testimonials-grid');
    if (tGrid) {
        let startX = 0;
        let startY = 0;
        let locked = false;
        let scrollStart = 0;
        tGrid.addEventListener('touchstart', (e) => {
            startX = e.touches[0].clientX;
            startY = e.touches[0].clientY;
            scrollStart = tGrid.scrollLeft;
            locked = false;
        }, { passive: true });
        tGrid.addEventListener('touchmove', (e) => {
            if (locked) return;
            const dx = Math.abs(e.touches[0].clientX - startX);
            const dy = Math.abs(e.touches[0].clientY - startY);
            if (dx > 10 && dx > dy) {
                locked = true;
                tGrid.style.overflow = 'hidden';
            }
        }, { passive: true });
        tGrid.addEventListener('touchend', (e) => {
            if (!locked) return;
            tGrid.style.overflow = '';
            const dx = e.changedTouches[0].clientX - startX;
            tGrid.scrollLeft = scrollStart;
            if (Math.abs(dx) > 40) {
                scrollTestimonials(dx < 0 ? 1 : -1);
            }
        });
    }

    document.addEventListener('click', (e) => {
        const menu = document.getElementById('mobile-menu');
        const toggle = document.getElementById('menu-toggle');
        if (menu && menu.classList.contains('open') &&
            !menu.contains(e.target) && !toggle.contains(e.target)) {
            closeMenu();
        }
    });
});
</script>

</BaseLayout>
